# =============================================================================
# Mandum Rimba — MODAL pipeline secret (modal_app.py)
#
# These are the keys the nightly ingest + tiles jobs need. They live in a Modal
# SECRET named "mandumrimba-env" (referenced by modal.Secret.from_name in
# modal_app.py), not in a deployed .env file.
#
# Create the secret from this file once you've filled it in:
#
#   cp .env.modal.example .env.modal     # then fill in real values
#   modal secret create mandumrimba-env \
#     MONGODB_URI="$(grep -E '^MONGODB_URI=' .env.modal | cut -d= -f2-)" \
#     ...   # or just paste the values in the Modal dashboard → Secrets → New
#
# Easiest: open the Modal dashboard, create a secret named "mandumrimba-env",
# and paste these key=value pairs.
#
# CRON_ENABLED is forced to "false" inside modal_app.py — do not rely on it here.
# =============================================================================

# Database (shared with the Vercel API)
MONGODB_URI=

# Cloudflare R2 — the pipeline writes PMTiles + raw archives here (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mandum-rimba

# Global Forest Watch Data API — gfw-alerts, gfw-annual, concessions, wdpa
GFW_API_KEY=

# Optional hosted sources — leave empty to skip that ingest job
TRASE_CSV_URL=
MODI_CSV_URL=
MINING_IUP_GEOJSON_URL=
# Override only if the BNPB DIBI / DesInventar export URL moves:
# DESINVENTAR_EXPORT_URL=

# Optional — only if you trigger admin endpoints from the pipeline
# ADMIN_API_KEY=
