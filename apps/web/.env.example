# =============================================================================
# Mandum Rimba, WEB environment (Vercel "web" project)
# All vars are NEXT_PUBLIC_* (exposed to the browser). Set them in the Vercel
# project settings; locally, copy to .env.local.
# =============================================================================

# Deployed API base (the Vercel "api" project URL), no trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Cloudflare R2 public base serving the PMTiles (== the bucket's public/custom
# domain URL), no trailing slash.
# Optional: absolute R2 host. Leave unset to serve /tiles/* and /species/*
# same-origin (proxied via next.config rewrites — see TILES_ORIGIN there).
# NEXT_PUBLIC_TILES_BASE_URL=

# Public site origin, no trailing slash, used for canonical/OG URLs, sitemap,
# robots, and JSON-LD. Set this to the production domain in deployment.
NEXT_PUBLIC_SITE_URL=https://mandumrimba.org

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty in dev so
# local builds never report into the production property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
