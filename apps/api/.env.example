# =============================================================================
# Mandum Rimba — API environment
#
# The SAME api code runs in two deployments:
#   • Vercel  → read-only REST serving        (apps/api, see vercel.json)
#   • Modal   → nightly ingest + tiles jobs    (modal_app.py, same code)
#
# Each var is tagged [vercel], [modal], or [both]. For the Modal deployment
# these go into the `mandumrimba-env` Modal secret (see ../../.env.modal.example),
# NOT a .env file. For local dev, fill what you need.
# =============================================================================

# --- Database --------------------------------------------------------- [both]
MONGODB_URI=mongodb://localhost:27017/forestwatch
# Mongoose pool size — keep small on Vercel (serverless) so concurrent cold
# starts don't exhaust Atlas connections. Default 5.
MONGO_POOL_SIZE=5

# --- Vercel API serving --------------------------------------------- [vercel]
# Local/container HTTP port. Vercel injects its own and ignores this.
PORT=4000
# Comma-separated CORS origins — set to the web domain in prod.
CORS_ORIGINS=http://localhost:3000
# MUST be "false" on Vercel AND Modal: scheduling is owned by Modal Cron, never
# by the in-process @nestjs/schedule timers.
CRON_ENABLED=false

# --- Admin (optional) ------------------------------------------------- [both]
# Guards POST /v1/admin/jobs/:name/run. On Vercel the triggers no-op (no jobs
# are registered there); only set if you expose admin endpoints.
ADMIN_API_KEY=change-me

# --- Cloudflare R2: tile + archive storage -------------------------- [modal]
# Only the pipeline writes to R2 (S3-compatible). The PUBLIC read URL is a WEB
# var (NEXT_PUBLIC_TILES_BASE_URL), not needed here.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mandum-rimba

# --- Data sources: ingest jobs -------------------------------------- [modal]
# Global Forest Watch Data API — gfw-alerts, gfw-annual, concessions, wdpa.
GFW_API_KEY=
# BNPB DIBI via the UNDRR DesInventar mirror (no key). Override only if it moves:
# DESINVENTAR_EXPORT_URL=https://www.desinventar.net/DesInventar/download/DI_export_idn.zip
# Optional hosted sources — leave empty to skip that job:
# Trase bulk CSV (download from trase.earth/open-data, host it, point here):
TRASE_CSV_URL=
# ESDM MODI mining registry CSV export:
MODI_CSV_URL=
# Official mining IUP permit boundaries as a hosted GeoJSON FeatureCollection.
# NOT openly published for Indonesia (ESDM MOMI is login-locked); set only with
# a credible, citable source. The mining FOOTPRINT (Maus dataset) shows
# regardless of this setting.
MINING_IUP_GEOJSON_URL=
