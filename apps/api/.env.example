# MongoDB Atlas (decide the IP whitelist approach on day 1 — see README §Deploy)
MONGODB_URI=mongodb://localhost:27017/forestwatch

# Server
PORT=4000
CORS_ORIGINS=http://localhost:3000

# Admin endpoints (manual job triggers, story publishing)
ADMIN_API_KEY=change-me

# Global Forest Watch Data API — https://data-api.globalforestwatch.org
# Used by: gfw-alerts, gfw-annual, concessions (oil palm/pulp/logging),
# wdpa (WDPA + PIPPIB moratorium). All vector sources come from this one API.
GFW_API_KEY=

# BNPB DIBI events come from the UNDRR DesInventar mirror (no key needed).
# Override the export URL only if the default moves:
# DESINVENTAR_EXPORT_URL=https://www.desinventar.net/DesInventar/download/DI_export_idn.zip

# --- optional sources without stable public endpoints (leave empty to skip) ---
# Trase bulk CSV (download from trase.earth/open-data, host it, point here):
TRASE_CSV_URL=
# ESDM MODI mining registry CSV export:
MODI_CSV_URL=
# Official mining concession (IUP permit) boundaries as a hosted GeoJSON
# FeatureCollection. NOT openly available for Indonesia (ESDM MOMI is
# login-locked); set this only with a credible source you can obtain + cite.
# Mining FOOTPRINT (actual mined land, all minerals, Aceh→Papua) is always
# shown via the Maus dataset regardless of this setting.
MINING_IUP_GEOJSON_URL=

# Cloudflare R2 (S3-compatible). Bucket holds PMTiles, raw archives, status JSON, imagery.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=forest-watch
R2_PUBLIC_BASE_URL=https://tiles.example.com

# Set to "false" to disable all cron scheduling (e.g. local dev)
CRON_ENABLED=true
